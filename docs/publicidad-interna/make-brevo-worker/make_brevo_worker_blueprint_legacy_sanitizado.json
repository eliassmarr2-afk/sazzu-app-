      "id": 7,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "authenticationType": "noAuth",
        "tlsType": "",
        "proxyKeychain": ""
      },
      "mapper": {
        "url": "https://api.brevo.com/v3/contacts",
        "method": "post",
        "headers": [
          {
            "name": "api-key",
            "value": "{{BREVO_API_KEY}}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          },
          {
            "name": "Accept",
            "value": "application/json"
          }
        ],
        "contentType": "json",
        "parseResponse": true,
        "stopOnHttpError": true,
        "allowRedirects": true,
        "shareCookies": false,
        "requestCompressedContent": true,
        "inputMethod": "jsonString",
        "jsonStringBodyContent": "{\n  \"email\": \"{{6.email}}\",\n  \"listIds\": [{{6.brevo_lista_id}}],\n  \"updateEnabled\": true\n}"
      },
      "metadata": {
        "note": "Payload mínimo legacy. Futuro: agregar attributes, nombre, telefono, fuente, UTM, campaña y metadata."
      },
      "onerror": [
        {
          "id": 10,
          "module": "http:MakeRequest",
          "version": 4,
          "parameters": {
            "authenticationType": "noAuth",
            "tlsType": "",
            "proxyKeychain": ""
          },
          "mapper": {
            "url": "{{SUPABASE_PROJECT_URL}}/rest/v1/rpc/rpc_brevo_marcar_trabajo_resultado",
            "method": "post",
            "headers": [
              {
                "name": "apikey",
                "value": "{{SUPABASE_SERVICE_ROLE_KEY}}"
              },
              {
                "name": "Authorization",
                "value": "Bearer {{SUPABASE_SERVICE_ROLE_KEY}}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Accept",
                "value": "application/json"
              }
            ],
            "contentType": "json",
            "parseResponse": true,
            "stopOnHttpError": true,
            "allowRedirects": true,
            "shareCookies": false,
            "requestCompressedContent": true,
            "inputMethod": "jsonString",
            "jsonStringBodyContent": "{\n  \"p_payload\": {\n    \"trabajo_id\": \"{{2.trabajo_id}}\",\n    \"estado\": \"error\",\n    \"cantidad_contactos_sincronizados\": 0,\n    \"cantidad_contactos_error\": 1,\n    \"make_execution_id\": null,\n    \"payload_respuesta\": {\n      \"origen\": \"make\",\n      \"fase\": \"sincronizacion_contactos_brevo\",\n      \"detalle\": \"Brevo rechazó o no pudo procesar al menos un contacto\"\n    },\n    \"errores\": [\n      {\n        \"modulo\": \"HTTP 7 · Brevo crear/actualizar contacto\",\n        \"tipo\": \"brevo_contact_sync_error\",\n        \"mensaje\": \"Error detectado durante la creación o actualización de contacto en Brevo\"\n      }\n    ],\n    \"metadata\": {\n      \"worker\": \"PD · Brevo Sync Worker\",\n      \"paso\": \"marcar_error\",\n      \"fuente_error\": \"brevo_contacts_api\"\n    }\n  }\n}"
          },
          "metadata": {
            "note": "Sanitizado. Se eliminó token suelto que estaba después del JSON en blueprint original."
          }
        }
      ]
    },
    {
      "id": 8,
      "module": "builtin:BasicAggregator",
      "version": 1,
      "parameters": {
        "feeder": 6
