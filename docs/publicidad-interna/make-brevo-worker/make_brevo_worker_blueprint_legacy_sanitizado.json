{
  "name": "Integration HTTP",
  "flow": [
    {
      "id": 11,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "authenticationType": "noAuth",
        "tlsType": "",
        "proxyKeychain": ""
      },
      "mapper": {
        "url": "{{SUPABASE_PROJECT_URL}}/rest/v1/rpc/rpc_brevo_worker_preflight",
        "method": "post",
        "headers": [
          {
            "name": "apikey",
            "value": "{{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Authorization",
            "value": "Bearer {{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          },
          {
            "name": "Accept",
            "value": "application/json"
          }
        ],
        "contentType": "json",
        "parseResponse": true,
        "stopOnHttpError": true,
        "allowRedirects": true,
        "shareCookies": false,
        "requestCompressedContent": true,
        "inputMethod": "jsonString",
        "jsonStringBodyContent": "{\n  \"p_payload\": {\n    \"limit\": 50\n  }\n}"
      },
      "metadata": {
        "note": "Preflight worker. Blueprint sanitizado: reemplazar variables placeholder dentro de Make, no versionar secretos."
      }
    },
    {
      "id": 1,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "authenticationType": "noAuth",
        "tlsType": "",
        "proxyKeychain": ""
      },
      "mapper": {
        "url": "{{SUPABASE_PROJECT_URL}}/rest/v1/vista_brevo_trabajos_pendientes_make?select=*&limit=1",
        "method": "get",
        "headers": [
          {
            "name": "apikey",
            "value": "{{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Authorization",
            "value": "Bearer {{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          },
          {
            "name": "Accept",
            "value": "application/json"
          }
        ],
        "parseResponse": true,
        "stopOnHttpError": true,
        "allowRedirects": true,
        "shareCookies": false,
        "requestCompressedContent": true
      },
      "metadata": {
        "note": "Lee 1 trabajo pendiente. Futuro: paginar o procesar lote controlado por preflight."
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicFeeder",
      "version": 1,
      "parameters": {},
      "filter": {
        "name": "Solo continuar si hay trabajos pendientes",
        "conditions": [
          [
            {
              "a": "{{1.data}}",
              "o": "array:greater",
              "b": "0"
            }
          ]
        ]
      },
      "mapper": {
        "array": "{{1.data}}"
      }
    },
    {
      "id": 4,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "authenticationType": "noAuth",
        "tlsType": "",
        "proxyKeychain": ""
      },
      "mapper": {
        "url": "{{SUPABASE_PROJECT_URL}}/rest/v1/rpc/rpc_brevo_marcar_trabajo_resultado",
        "method": "post",
        "headers": [
          {
            "name": "apikey",
            "value": "{{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Authorization",
            "value": "Bearer {{SUPABASE_SERVICE_ROLE_KEY}}"
          },
          {
            "name": "Content-Type",
            "value": "application/json"
          },
          {
            "name": "Accept",
            "value": "application/json"
          }
        ],
        "contentType": "json",
        "parseResponse": true,
        "stopOnHttpError": true,
        "allowRedirects": true,
        "shareCookies": false,
        "requestCompressedContent": true,
        "inputMethod": "jsonString",
        "jsonStringBodyContent": "{\n  \"p_payload\": {\n    \"trabajo_id\": \"{{2.trabajo_id}}\",\n    \"estado\": \"procesando\",\n    \"cantidad_contactos_sincronizados\": 0,\n    \"cantidad_contactos_error\": 0,\n    \"make_execution_id\": null,\n    \"payload_respuesta\": {\n      \"origen\": \"make\",\n      \"fase\": \"inicio_procesamiento\"\n    },\n    \"errores\": [],\n    \"metadata\": {\n      \"worker\": \"PD · Brevo Sync Worker\",\n      \"paso\": \"marcar_procesando\"\n    }\n  }\n}"
      }
    },
    {
      "id": 5,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "authenticationType": "noAuth",
        "tlsType": "",
        "proxyKeychain": ""
      },
      "mapper": {
        "url": "{{SUPABASE_PROJECT_URL}}/rest/v1/rpc/rpc_brevo_obtener_contactos_trabajo",
